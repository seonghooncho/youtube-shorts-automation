#!/bin/bash
exec > >(tee /var/log/ytshorts-userdata.log | logger -t ytshorts-userdata -s 2>/dev/console) 2>&1
set -euo pipefail

cleanup() {
  if [[ -n "$${S3_BUCKET_NAME:-}" ]]; then
    aws s3 cp /var/log/ytshorts-userdata.log "s3://$${S3_BUCKET_NAME}/logs/userdata-$${MODE}-$(date +%Y%m%d-%H%M%S).log" || true
    [[ -d /opt/ytshorts/logs ]] && aws s3 cp /opt/ytshorts/logs/ "s3://$${S3_BUCKET_NAME}/logs/" --recursive || true
  fi
  shutdown -h now || poweroff || halt || true
}
trap cleanup EXIT

export DEBIAN_FRONTEND=noninteractive
export AWS_DEFAULT_REGION="${aws_region}"
export AWS_REGION="${aws_region}"
export MODE="__MODE__"
export REPO_URL="${repository_url}"
export GIT_REF="${git_ref}"

retry() {
  local n=0
  until "$@"; do
    n=$((n + 1))
    [[ $n -ge 5 ]] && return 1
    sleep 5
  done
}

get_param() {
  aws ssm get-parameter --name "$1" --with-decryption --region "$AWS_REGION" --query 'Parameter.Value' --output text 2>/dev/null || true
}

retry apt-get update -y
retry apt-get install -y --no-install-recommends git awscli jq ca-certificates python3 python3-venv ffmpeg

APP_ROOT=/opt/ytshorts
REPO_DIR="$APP_ROOT/repo"
LOG_DIR="$APP_ROOT/logs"
mkdir -p "$APP_ROOT" "$LOG_DIR"

if [[ -d "$REPO_DIR/.git" ]]; then
  git -C "$REPO_DIR" fetch --depth=1 origin "$GIT_REF" || git -C "$REPO_DIR" fetch origin
else
  rm -rf "$REPO_DIR"
  git clone --depth=1 --branch "$GIT_REF" "$REPO_URL" "$REPO_DIR" || git clone --depth=1 "$REPO_URL" "$REPO_DIR"
fi
cd "$REPO_DIR"
git checkout "$GIT_REF" || true
git pull --ff-only origin "$GIT_REF" || true

python3 -m venv .venv
. .venv/bin/activate
pip install -U pip
if [[ "$MODE" == "upload" ]]; then
  pip install -r requirements-upload-scheduler.txt
else
  pip install -r requirements-batch-generate.txt
fi

export S3_BUCKET_NAME="$(get_param /ytshorts/S3_BUCKET_NAME)"
export OPENAI_API_KEY="$(get_param /ytshorts/OPENAI_API_KEY)"
export HF_TOKEN="$(get_param /ytshorts/HF_TOKEN)"
export SLACK_WEBHOOK_URL="$(get_param /ytshorts/SLACK_WEBHOOK_URL)"
export PIXABAY_API_KEY="$(get_param /ytshorts/PIXABAY_API_KEY)"
export YOUTUBE_API_KEY="$(get_param /ytshorts/YOUTUBE_API_KEY)"
export YOUTUBE_CLIENT_ID="$(get_param /ytshorts/YOUTUBE_CLIENT_ID)"
export YOUTUBE_CLIENT_SECRET="$(get_param /ytshorts/YOUTUBE_CLIENT_SECRET)"
export YOUTUBE_REFRESH_TOKEN="$(get_param /ytshorts/YOUTUBE_REFRESH_TOKEN)"
export YOUTUBE_TOKEN_URI="$(get_param /ytshorts/YOUTUBE_TOKEN_URI)"
export REDDIT_CLIENT_ID="$(get_param /ytshorts/REDDIT_CLIENT_ID)"
export REDDIT_CLIENT_SECRET="$(get_param /ytshorts/REDDIT_CLIENT_SECRET)"
export REDDIT_USER_AGENT="$(get_param /ytshorts/REDDIT_USER_AGENT)"
export TARGET_PLATFORMS="$${TARGET_PLATFORMS:-youtube}"
export YOUTUBE_PRIVACY_STATUS="$${YOUTUBE_PRIVACY_STATUS:-private}"
export REDDIT_FALLBACK_PROVIDER="$${REDDIT_FALLBACK_PROVIDER:-pullpush}"

if [[ -z "$S3_BUCKET_NAME" ]]; then
  export S3_BUCKET_NAME="${bucket_name}"
fi

python runner.py 2>&1 | tee "$LOG_DIR/runner-$${MODE}-$(date +%Y%m%d-%H%M%S).log"
